# Copy to .env and fill in values. Never commit .env.

# --- Groq (primary LLM) ---
GROQ_API_KEY=
# Model id from https://console.groq.com/docs/models
GROQ_MODEL=mixtral-8x7b-32768
GROQ_MAX_TOKENS=3072
# Tight cap for "who is this" / name questions (keeps answers short; avoid raising above ~512)
# GROQ_MAX_TOKENS_IDENTITY=256
GROQ_TEMPERATURE=0.35
# Optional: reduce rambling / repeated phrases (Groq OpenAI-compatible API)
# GROQ_TOP_P=0.92
# GROQ_FREQUENCY_PENALTY=0.12

# --- Hugging Face (hosted inference + hub downloads) ---
HUGGINGFACE_API_KEY=

# --- Retrieval & documents ---
RETRIEVER_K=5
# "Who is this" / name — fewer, header-leaning chunks (not whole resume)
# RETRIEVER_K_IDENTITY=5
# Used for broad prompts (e.g. "tell me about this resume") — pulls more chunks than RETRIEVER_K
RETRIEVER_K_OVERVIEW=10
# Used when comparing or relating multiple uploads (e.g. "how are these files related?")
RETRIEVER_K_MULTI=15
MULTI_FILE_CHUNKS_PER_FILE=5
MULTI_FILE_POOL_K=180
DOC_CHUNK_SIZE=1000
DOC_CHUNK_OVERLAP=200

# Sentence-Transformers model name
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Small model used only if hosted HF calls fail (local transformers pipeline)
HF_LOCAL_MODEL=google/flan-t5-small
